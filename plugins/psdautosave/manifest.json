{
  "manifestVersion": 5,
  "id": "com.makienn.photoshop.psdautosave",
  "name": "psdautosave",
  "version": "0.1.1",
  "main": "index.html",
  "requiredPermissions": {
    "localFileSystem": "request"
  },
  "host": [
    {
      "app": "PS",
      "minVersion": "25.0.0",
      "data": {
        "apiVersion": 2
      }
    }
  ],
  "icons": [
    {
      "width": 23,
      "height": 23,
      "path": "icons/dark.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "darkest",
        "dark",
        "medium"
      ]
    },
    {
      "width": 23,
      "height": 23,
      "path": "icons/light.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "lightest",
        "light"
      ]
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "psdAutoSave",
      "label": {
        "default": "psdautosave"
      },
      "minimumSize": {
        "width": 240,
        "height": 180
      },
      "maximumSize": {
        "width": 640,
        "height": 900
      },
      "preferredDockedSize": {
        "width": 300,
        "height": 360
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 460
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/dark.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "dark",
            "darkest"
          ],
          "species": [
            "generic"
          ]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/light.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "lightest",
            "light"
          ],
          "species": [
            "generic"
          ]
        }
      ]
    }
  ]
}
