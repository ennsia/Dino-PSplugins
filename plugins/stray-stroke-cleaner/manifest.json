{
  "manifestVersion": 5,
  "id": "com.makienn.photoshop.stray-stroke-cleaner",
  "name": "Stray Stroke Cleaner",
  "version": "0.1.0",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "24.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "strayStrokeCleaner",
      "label": {
        "default": "Stray Stroke Cleaner"
      },
      "minimumSize": {
        "width": 320,
        "height": 420
      },
      "maximumSize": {
        "width": 640,
        "height": 900
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 520
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 600
      }
    }
  ]
}
