{
  "manifestVersion": 5,
  "id": "com.makienn.photoshop.layer-quick-jump",
  "name": "Layer Quick Jump",
  "version": "0.2.0",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "25.0.0",
      "data": {
        "apiVersion": 2
      }
    }
  ],
  "icons": [
    {
      "width": 23,
      "height": 23,
      "path": "icons/dark.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "darkest",
        "dark",
        "medium"
      ]
    },
    {
      "width": 23,
      "height": 23,
      "path": "icons/light.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "lightest",
        "light"
      ]
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "layerQuickJump",
      "label": {
        "default": "Layer Quick Jump"
      },
      "minimumSize": {
        "width": 300,
        "height": 260
      },
      "maximumSize": {
        "width": 520,
        "height": 640
      },
      "preferredDockedSize": {
        "width": 340,
        "height": 360
      },
      "preferredFloatingSize": {
        "width": 380,
        "height": 380
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/dark.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "dark",
            "darkest"
          ],
          "species": [
            "generic"
          ]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/light.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "lightest",
            "light"
          ],
          "species": [
            "generic"
          ]
        }
      ]
    }
  ]
}
