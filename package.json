{
  "name": "photoshop-plugins",
  "version": "0.1.0",
  "description": "A personal Photoshop / UXP plugin toolkit for ACG and game-art workflows.",
  "private": false,
  "type": "module",
  "scripts": {
    "lint": "node scripts/validate-manifests.mjs",
    "test:layer-quick-jump": "node tests/layer-quick-jump.test.cjs && node tests/layer-quick-jump-ui.test.cjs",
    "test:color-layer-batch-merge": "node tests/color-layer-batch-merge.test.cjs && node tests/color-layer-batch-merge-executor.test.cjs",
    "package:plugin": "node scripts/package-plugin.mjs",
    "package:layer-quick-jump": "node scripts/package-plugin.mjs layer-quick-jump",
    "package:layer-quick-jump-cep": "node scripts/package-cep-plugin.mjs layer-quick-jump-cep",
    "verify:layer-quick-jump-ccx": "node scripts/verify-ccx.mjs dist/layer-quick-jump/0.2.0/Dino-layer-quick-jump_PS.ccx"
  },
  "keywords": [
    "photoshop",
    "uxp",
    "plugin",
    "creative-tools"
  ],
  "license": "Apache-2.0"
}
